<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="InventorySummary" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Normal" fontName="THSarabunNew" fontSize="12" pdfFontName="THSarabunNew" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="NormalBold" style="Normal" isBold="true"/>
    <style name="Header" style="NormalBold" fontSize="16"/>
    <style name="TableHeader" style="NormalBold" backcolor="#E0E0E0"/>
    <style name="Currency" style="Normal" pattern="#,##0.00"/>

    <parameter name="companyName" class="java.lang.String"/>
    <parameter name="reportDate" class="java.lang.String"/>
    <parameter name="totalItems" class="java.lang.Integer"/>
    <parameter name="totalValue" class="java.math.BigDecimal"/>
    <parameter name="lowStockCount" class="java.lang.Integer"/>

    <field name="partCode" class="java.lang.String"/>
    <field name="partName" class="java.lang.String"/>
    <field name="category" class="java.lang.String"/>
    <field name="stockQty" class="java.lang.Integer"/>
    <field name="unitCost" class="java.math.BigDecimal"/>
    <field name="totalValue" class="java.math.BigDecimal"/>
    <field name="minStock" class="java.lang.Integer"/>
    <field name="location" class="java.lang.String"/>

    <pageHeader>
        <band height="60">
            <textField><reportElement x="0" y="5" width="300" height="20" style="NormalBold" fontSize="14"/><textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="5" width="205" height="25" style="Header"/><textFieldExpression><![CDATA["\u0e23\u0e32\u0e22\u0e07\u0e32\u0e19\u0e2a\u0e34\u0e19\u0e04\u0e49\u0e32\u0e04\u0e07\u0e04\u0e25\u0e31\u0e07 / INVENTORY SUMMARY"]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="30" width="205" height="20" style="Normal"/><textFieldExpression><![CDATA["\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48: " + $P{reportDate}]]></textFieldExpression></textField>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="25">
            <staticText><reportElement x="5" y="3" width="80" height="20" style="TableHeader"/><text><![CDATA[\u0e23\u0e2b\u0e31\u0e2a]]></text></staticText>
            <staticText><reportElement x="90" y="3" width="120" height="20" style="TableHeader"/><text><![CDATA[\u0e0a\u0e37\u0e48\u0e2d\u0e2a\u0e34\u0e19\u0e04\u0e49\u0e32]]></text></staticText>
            <staticText><reportElement x="215" y="3" width="80" height="20" style="TableHeader"/><text><![CDATA[\u0e2b\u0e21\u0e27\u0e14\u0e2b\u0e21\u0e39\u0e48]]></text></staticText>
            <staticText><reportElement x="300" y="3" width="40" height="20" style="TableHeader"/><text><![CDATA[\u0e08\u0e33\u0e19\u0e27\u0e19]]></text></staticText>
            <staticText><reportElement x="345" y="3" width="70" height="20" style="TableHeader"/><text><![CDATA[\u0e23\u0e32\u0e04\u0e32\u0e15\u0e49\u0e19\u0e17\u0e38\u0e19]]></text></staticText>
            <staticText><reportElement x="420" y="3" width="70" height="20" style="TableHeader"/><text><![CDATA[\u0e21\u0e39\u0e25\u0e04\u0e48\u0e32]]></text></staticText>
            <staticText><reportElement x="495" y="3" width="55" height="20" style="TableHeader"/><text><![CDATA[\u0e15\u0e33\u0e41\u0e2b\u0e19\u0e48\u0e07]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField><reportElement x="5" y="0" width="80" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{partCode}]]></textFieldExpression></textField>
            <textField><reportElement x="90" y="0" width="120" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{partName}]]></textFieldExpression></textField>
            <textField><reportElement x="215" y="0" width="80" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{category}]]></textFieldExpression></textField>
            <textField><reportElement x="300" y="0" width="40" height="20" style="Normal" textAlignment="Center"/><textFieldExpression><![CDATA[$F{stockQty}]]></textFieldExpression></textField>
            <textField><reportElement x="345" y="0" width="70" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{unitCost}]]></textFieldExpression></textField>
            <textField><reportElement x="420" y="0" width="70" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{totalValue}]]></textFieldExpression></textField>
            <textField><reportElement x="495" y="0" width="55" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{location}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="80">
            <staticText><reportElement x="350" y="5" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e27\u0e21\u0e21\u0e39\u0e25\u0e04\u0e48\u0e32:]]></text></staticText>
            <textField><reportElement x="450" y="5" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{totalValue}]]></textFieldExpression></textField>
            <textField><reportElement x="10" y="30" width="250" height="20" style="Normal"/><textFieldExpression><![CDATA["\u0e08\u0e33\u0e19\u0e27\u0e19\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23: " + $P{totalItems}]]></textFieldExpression></textField>
            <textField><reportElement x="10" y="50" width="250" height="20" style="Normal"/><textFieldExpression><![CDATA["\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23\u0e2a\u0e15\u0e47\u0e2d\u0e01\u0e15\u0e48\u0e33: " + $P{lowStockCount}]]></textFieldExpression></textField>
        </band>
    </summary>
</jasperReport>
