<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="JobCard" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Normal" fontName="THSarabunNew" fontSize="12" pdfFontName="THSarabunNew" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="NormalBold" style="Normal" isBold="true"/>
    <style name="Header" style="NormalBold" fontSize="16"/>
    <style name="TableHeader" style="NormalBold" backcolor="#E0E0E0"/>
    <style name="Currency" style="Normal" pattern="#,##0.00"/>

    <parameter name="companyName" class="java.lang.String"/>
    <parameter name="jobNo" class="java.lang.String"/>
    <parameter name="jobDate" class="java.lang.String"/>
    <parameter name="customerName" class="java.lang.String"/>
    <parameter name="customerPhone" class="java.lang.String"/>
    <parameter name="licensePlate" class="java.lang.String"/>
    <parameter name="carModel" class="java.lang.String"/>
    <parameter name="carColor" class="java.lang.String"/>
    <parameter name="mileage" class="java.lang.String"/>
    <parameter name="mechanicName" class="java.lang.String"/>
    <parameter name="serviceAdvisor" class="java.lang.String"/>
    <parameter name="complaint" class="java.lang.String"/>
    <parameter name="remark" class="java.lang.String"/>
    <parameter name="totalParts" class="java.math.BigDecimal"/>
    <parameter name="totalLabor" class="java.math.BigDecimal"/>
    <parameter name="grandTotal" class="java.math.BigDecimal"/>

    <field name="type" class="java.lang.String"/>
    <field name="description" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>
    <field name="unitPrice" class="java.math.BigDecimal"/>
    <field name="totalPrice" class="java.math.BigDecimal"/>

    <pageHeader>
        <band height="60">
            <textField><reportElement x="0" y="5" width="300" height="20" style="NormalBold" fontSize="14"/><textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="5" width="205" height="25" style="Header"/><textFieldExpression><![CDATA["\u0e43\u0e1a\u0e07\u0e32\u0e19\u0e0b\u0e48\u0e2d\u0e21 / JOB CARD"]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="30" width="205" height="20" style="Normal"/><textFieldExpression><![CDATA["\u0e40\u0e25\u0e02\u0e17\u0e35\u0e48: " + $P{jobNo}]]></textFieldExpression></textField>
        </band>
    </pageHeader>

    <title>
        <band height="120">
            <rectangle><reportElement x="0" y="0" width="555" height="120" backcolor="#F5F5F5"/></rectangle>
            <staticText><reportElement x="10" y="5" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32:]]></text></staticText>
            <textField><reportElement x="120" y="5" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{customerName}]]></textFieldExpression></textField>
            <staticText><reportElement x="10" y="25" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e42\u0e17\u0e23:]]></text></staticText>
            <textField><reportElement x="120" y="25" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{customerPhone}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="5" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e17\u0e30\u0e40\u0e1a\u0e35\u0e22\u0e19:]]></text></staticText>
            <textField><reportElement x="440" y="5" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{licensePlate}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="25" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e38\u0e48\u0e19:]]></text></staticText>
            <textField><reportElement x="440" y="25" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{carModel}]]></textFieldExpression></textField>
            <staticText><reportElement x="10" y="50" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e2a\u0e35:]]></text></staticText>
            <textField><reportElement x="120" y="50" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{carColor}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="50" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e44\u0e21\u0e25\u0e4c:]]></text></staticText>
            <textField><reportElement x="440" y="50" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{mileage}]]></textFieldExpression></textField>
            <staticText><reportElement x="10" y="75" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e0a\u0e48\u0e32\u0e07:]]></text></staticText>
            <textField><reportElement x="120" y="75" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{mechanicName}]]></textFieldExpression></textField>
            <staticText><reportElement x="10" y="95" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e41\u0e08\u0e49\u0e07\u0e1b\u0e31\u0e0d\u0e2b\u0e32:]]></text></staticText>
            <textField><reportElement x="120" y="95" width="400" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{complaint}]]></textFieldExpression></textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText><reportElement x="5" y="3" width="60" height="20" style="TableHeader"/><text><![CDATA[\u0e1b\u0e23\u0e30\u0e40\u0e20\u0e17]]></text></staticText>
            <staticText><reportElement x="70" y="3" width="250" height="20" style="TableHeader"/><text><![CDATA[\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23]]></text></staticText>
            <staticText><reportElement x="325" y="3" width="50" height="20" style="TableHeader"/><text><![CDATA[\u0e08\u0e33\u0e19\u0e27\u0e19]]></text></staticText>
            <staticText><reportElement x="380" y="3" width="80" height="20" style="TableHeader"/><text><![CDATA[\u0e23\u0e32\u0e04\u0e32/\u0e2b\u0e19\u0e48\u0e27\u0e22]]></text></staticText>
            <staticText><reportElement x="465" y="3" width="85" height="20" style="TableHeader"/><text><![CDATA[\u0e23\u0e27\u0e21]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField><reportElement x="5" y="0" width="60" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{type}]]></textFieldExpression></textField>
            <textField><reportElement x="70" y="0" width="250" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{description}]]></textFieldExpression></textField>
            <textField><reportElement x="325" y="0" width="50" height="20" style="Normal" textAlignment="Center"/><textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression></textField>
            <textField><reportElement x="380" y="0" width="80" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{unitPrice}]]></textFieldExpression></textField>
            <textField><reportElement x="465" y="0" width="85" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{totalPrice}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="100">
            <staticText><reportElement x="350" y="5" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e27\u0e21\u0e2d\u0e30\u0e44\u0e2b\u0e25\u0e48:]]></text></staticText>
            <textField><reportElement x="450" y="5" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{totalParts}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="25" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e27\u0e21\u0e04\u0e48\u0e32\u0e41\u0e23\u0e07:]]></text></staticText>
            <textField><reportElement x="450" y="25" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{totalLabor}]]></textFieldExpression></textField>
            <staticText><reportElement x="330" y="50" width="110" height="25" style="NormalBold" fontSize="14"/><text><![CDATA[\u0e23\u0e27\u0e21\u0e17\u0e31\u0e49\u0e07\u0e2b\u0e21\u0e14:]]></text></staticText>
            <textField><reportElement x="450" y="50" width="100" height="25" style="NormalBold" pattern="#,##0.00" fontSize="14"/><textFieldExpression><![CDATA[$P{grandTotal}]]></textFieldExpression></textField>
        </band>
    </summary>
</jasperReport>
