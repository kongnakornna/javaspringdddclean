<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="DebitNote" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Normal" fontName="THSarabunNew" fontSize="12" pdfFontName="THSarabunNew" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="NormalBold" style="Normal" isBold="true"/>
    <style name="Header" style="NormalBold" fontSize="16"/>
    <style name="Currency" style="Normal" pattern="#,##0.00"/>

    <parameter name="companyName" class="java.lang.String"/>
    <parameter name="debitNoteNo" class="java.lang.String"/>
    <parameter name="debitNoteDate" class="java.lang.String"/>
    <parameter name="referenceInvoiceNo" class="java.lang.String"/>
    <parameter name="customerName" class="java.lang.String"/>
    <parameter name="reason" class="java.lang.String"/>
    <parameter name="totalAmount" class="java.math.BigDecimal"/>
    <parameter name="approvedBy" class="java.lang.String"/>

    <field name="lineNo" class="java.lang.Integer"/>
    <field name="description" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>

    <pageHeader>
        <band height="60">
            <textField><reportElement x="0" y="5" width="300" height="20" style="NormalBold" fontSize="14"/><textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="5" width="205" height="25" style="Header"/><textFieldExpression><![CDATA["\u0e43\u0e1a\u0e40\u0e1e\u0e34\u0e48\u0e21\u0e2b\u0e19\u0e35\u0e49 / DEBIT NOTE"]]></textFieldExpression></textField>
            <textField><reportElement x="350" y="30" width="205" height="20" style="Normal"/><textFieldExpression><![CDATA["\u0e40\u0e25\u0e02\u0e17\u0e35\u0e48: " + $P{debitNoteNo}]]></textFieldExpression></textField>
        </band>
    </pageHeader>

    <title>
        <band height="50">
            <staticText><reportElement x="10" y="5" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e25\u0e39\u0e01\u0e04\u0e49\u0e32:]]></text></staticText>
            <textField><reportElement x="120" y="5" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{customerName}]]></textFieldExpression></textField>
            <staticText><reportElement x="10" y="25" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e2d\u0e49\u0e32\u0e07\u0e2d\u0e34\u0e07\u0e43\u0e1a\u0e41\u0e08\u0e49\u0e07\u0e2b\u0e19\u0e35\u0e49:]]></text></staticText>
            <textField><reportElement x="120" y="25" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{referenceInvoiceNo}]]></textFieldExpression></textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText><reportElement x="5" y="3" width="30" height="20" style="NormalBold"/><text>#</text></staticText>
            <staticText><reportElement x="40" y="3" width="350" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23]]></text></staticText>
            <staticText><reportElement x="450" y="3" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e08\u0e33\u0e19\u0e27\u0e19]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField><reportElement x="5" y="0" width="30" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{lineNo}]]></textFieldExpression></textField>
            <textField><reportElement x="40" y="0" width="350" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{description}]]></textFieldExpression></textField>
            <textField><reportElement x="450" y="0" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="80">
            <staticText><reportElement x="350" y="5" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e27\u0e21\u0e40\u0e07\u0e34\u0e19:]]></text></staticText>
            <textField><reportElement x="450" y="5" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{totalAmount}]]></textFieldExpression></textField>
            <staticText><reportElement x="10" y="30" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e40\u0e2b\u0e15\u0e38\u0e1c\u0e25:]]></text></staticText>
            <textField><reportElement x="120" y="30" width="300" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{reason}]]></textFieldExpression></textField>
            <textField><reportElement x="380" y="55" width="175" height="20" style="Normal"/><textFieldExpression><![CDATA["\u0e1c\u0e39\u0e49\u0e2d\u0e19\u0e38\u0e21\u0e31\u0e15\u0e34: " + $P{approvedBy}]]></textFieldExpression></textField>
        </band>
    </summary>
</jasperReport>
