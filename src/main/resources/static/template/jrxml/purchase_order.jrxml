<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="PurchaseOrder" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Normal" fontName="THSarabunNew" fontSize="12" pdfFontName="THSarabunNew" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="NormalBold" style="Normal" isBold="true"/>
    <style name="Header" style="NormalBold" fontSize="16"/>
    <style name="Currency" style="Normal" pattern="#,##0.00"/>

    <parameter name="companyName" class="java.lang.String"/>
    <parameter name="companyAddress" class="java.lang.String"/>
    <parameter name="poNo" class="java.lang.String"/>
    <parameter name="poDate" class="java.lang.String"/>
    <parameter name="supplierName" class="java.lang.String"/>
    <parameter name="supplierAddress" class="java.lang.String"/>
    <parameter name="supplierPhone" class="java.lang.String"/>
    <parameter name="supplierTaxId" class="java.lang.String"/>
    <parameter name="deliveryDate" class="java.lang.String"/>
    <parameter name="paymentTerms" class="java.lang.String"/>
    <parameter name="subtotal" class="java.math.BigDecimal"/>
    <parameter name="discount" class="java.math.BigDecimal"/>
    <parameter name="taxAmount" class="java.math.BigDecimal"/>
    <parameter name="grandTotal" class="java.math.BigDecimal"/>
    <parameter name="remark" class="java.lang.String"/>
    <parameter name="createdBy" class="java.lang.String"/>

    <field name="lineNo" class="java.lang.Integer"/>
    <field name="partCode" class="java.lang.String"/>
    <field name="description" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>
    <field name="unitPrice" class="java.math.BigDecimal"/>
    <field name="totalPrice" class="java.math.BigDecimal"/>

    <pageHeader>
        <band height="60">
            <textField>
                <reportElement x="0" y="5" width="300" height="20" style="NormalBold" fontSize="14"/>
                <textFieldExpression><![CDATA[$P{companyName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="5" width="205" height="25" style="Header"/>
                <textFieldExpression><![CDATA["\u0e43\u0e1a\u0e2a\u0e31\u0e48\u0e07\u0e0b\u0e37\u0e49\u0e2d / PURCHASE ORDER"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="30" width="205" height="20" style="Normal"/>
                <textFieldExpression><![CDATA["\u0e40\u0e25\u0e02\u0e17\u0e35\u0e48: " + $P{poNo}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>

    <title>
        <band height="100">
            <staticText><reportElement x="10" y="5" width="100" height="20" style="NormalBold"/><text><![CDATA[\u0e1c\u0e39\u0e49\u0e08\u0e33\u0e2b\u0e19\u0e48\u0e32\u0e22 (Supplier):]]></text></staticText>
            <textField><reportElement x="120" y="5" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{supplierName}]]></textFieldExpression></textField>
            <textField><reportElement x="120" y="25" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{supplierAddress}]]></textFieldExpression></textField>
            <textField><reportElement x="120" y="45" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA["Tel: " + $P{supplierPhone} + " | Tax ID: " + $P{supplierTaxId}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="5" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48:]]></text></staticText>
            <textField><reportElement x="440" y="5" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{poDate}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="25" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e01\u0e33\u0e2b\u0e19\u0e14\u0e2a\u0e48\u0e07:]]></text></staticText>
            <textField><reportElement x="440" y="25" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{deliveryDate}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="45" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e40\u0e07\u0e37\u0e48\u0e2d\u0e19\u0e44\u0e21:]]></text></staticText>
            <textField><reportElement x="440" y="45" width="100" height="20" style="Normal"/><textFieldExpression><![CDATA[$P{paymentTerms}]]></textFieldExpression></textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <staticText><reportElement x="5" y="3" width="30" height="20" style="NormalBold"/><text>#</text></staticText>
            <staticText><reportElement x="40" y="3" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e2b\u0e31\u0e2a]]></text></staticText>
            <staticText><reportElement x="125" y="3" width="200" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e32\u0e22\u0e01\u0e32\u0e23]]></text></staticText>
            <staticText><reportElement x="330" y="3" width="50" height="20" style="NormalBold"/><text><![CDATA[\u0e08\u0e33\u0e19\u0e27\u0e19]]></text></staticText>
            <staticText><reportElement x="385" y="3" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e32\u0e04\u0e32/\u0e2b\u0e19\u0e48\u0e27\u0e22]]></text></staticText>
            <staticText><reportElement x="470" y="3" width="80" height="20" style="NormalBold"/><text><![CDATA[\u0e23\u0e27\u0e21]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField><reportElement x="5" y="0" width="30" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{lineNo}]]></textFieldExpression></textField>
            <textField><reportElement x="40" y="0" width="80" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{partCode}]]></textFieldExpression></textField>
            <textField><reportElement x="125" y="0" width="200" height="20" style="Normal"/><textFieldExpression><![CDATA[$F{description}]]></textFieldExpression></textField>
            <textField><reportElement x="330" y="0" width="50" height="20" style="Normal" textAlignment="Center"/><textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression></textField>
            <textField><reportElement x="385" y="0" width="80" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{unitPrice}]]></textFieldExpression></textField>
            <textField><reportElement x="470" y="0" width="80" height="20" style="Currency"/><textFieldExpression><![CDATA[$F{totalPrice}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="100">
            <staticText><reportElement x="370" y="5" width="70" height="20" style="NormalBold"/><text><![CDATA[\u0e22\u0e2d\u0e14\u0e23\u0e27\u0e21:]]></text></staticText>
            <textField><reportElement x="450" y="5" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{subtotal}]]></textFieldExpression></textField>
            <staticText><reportElement x="370" y="25" width="70" height="20" style="NormalBold"/><text><![CDATA[\u0e2a\u0e48\u0e27\u0e19\u0e25\u0e14:]]></text></staticText>
            <textField><reportElement x="450" y="25" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{discount}]]></textFieldExpression></textField>
            <staticText><reportElement x="370" y="45" width="70" height="20" style="NormalBold"/><text><![CDATA[\u0e20\u0e32\u0e29\u0e35:]]></text></staticText>
            <textField><reportElement x="450" y="45" width="100" height="20" style="Currency"/><textFieldExpression><![CDATA[$P{taxAmount}]]></textFieldExpression></textField>
            <staticText><reportElement x="350" y="70" width="90" height="25" style="NormalBold" fontSize="14"/><text><![CDATA[\u0e22\u0e2d\u0e14\u0e2a\u0e38\u0e17\u0e18\u0e34:]]></text></staticText>
            <textField><reportElement x="450" y="70" width="100" height="25" style="NormalBold" pattern="#,##0.00" fontSize="14"/><textFieldExpression><![CDATA[$P{grandTotal}]]></textFieldExpression></textField>
        </band>
    </summary>
</jasperReport>
