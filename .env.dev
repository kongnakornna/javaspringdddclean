# ==================================================================
# Spring Boot DDD Template - Environment Configuration
# ==================================================================
# Copy this file to .env and configure your environment-specific values
# WARNING: Never commit .env file to version control!

# ==================================================================
# Application Configuration
# ==================================================================
# Active Spring profile: dev, prod, test
SPRING_PROFILES_ACTIVE=dev

# ==================================================================
# Server Configuration
# ==================================================================
SERVER_PORT=1080
SERVER_SERVLET_CONTEXT_PATH=/api

# ==================================================================
# Database Configuration - PostgreSQL (Main Database)
# ==================================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/icmonapp?useSSL=false
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# ==================================================================
# JPA/Hibernate Configuration
# ==================================================================
# Options: create, create-drop, update, validate, none
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA=public
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# ==================================================================
# MongoDB Configuration (Logging Database)
# ==================================================================
DATA_MONGODB_HOST=localhost
DATA_MONGODB_PORT=27017
DATA_MONGODB_DATABASE=app_logs
DATA_MONGODB_USERNAME=
DATA_MONGODB_PASSWORD=
DATA_MONGODB_AUTHENTICATION_DATABASE=

# ==================================================================
# Neo4j Configuration (Graph Database)
# ==================================================================
DATA_NEO4J_URI=neo4j://localhost:7687
DATA_NEO4J_USER=neo4j
DATA_NEO4J_PASSWORD=password

# ==================================================================
# Security Configuration - JWT
# ==================================================================
# Generate your own JWT keys for production!
# You can use: openssl genrsa -out private.pem 2048
#              openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY=iCmon@1234
JWT_PRIVATE_KEY=iCmon@2988

# JWT Token expiration (in milliseconds)
JWT_EXPIRATION=86400000

# ==================================================================
# Logging Configuration
# ==================================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_TEMPLATE_APP=DEBUG
LOGGING_PATTERN_CONSOLE=%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx

# ==================================================================
# Monitoring & Observability
# ==================================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# ==================================================================
# Development Tools (Dev Profile Only)
# ==================================================================
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_LIVERELOAD_ENABLED=true

# ==================================================================
# Cache Configuration (Optional)
# ==================================================================
SPRING_CACHE_TYPE=simple
SPRING_CACHE_CACHE_NAMES=users,companies,default

# ==================================================================
# Mail Configuration (Optional)
# ==================================================================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ==================================================================
# File Upload Configuration
# ==================================================================
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# ==================================================================
# Async Configuration
# ==================================================================
SPRING_TASK_EXECUTION_POOL_CORE_SIZE=2
SPRING_TASK_EXECUTION_POOL_MAX_SIZE=5
SPRING_TASK_EXECUTION_POOL_QUEUE_CAPACITY=10000

# ==================================================================
# Custom Application Properties
# ==================================================================
APP_NAME=icmonapi
APP_VERSION=1.0.0
APP_DESCRIPTION=A modern template for Spring Boot applications using DDD and Clean Architecture
APP_CONTACT_NAME=kongnakorn jantakun
APP_CONTACT_EMAIL=kongnakornjantakun@gmail.com

# ==================================================================
# Docker Configuration (when running with Docker)
# ==================================================================
# Uncomment and adjust when using Docker containers
# SPRING_DATASOURCE_URL=jdbc:postgresql://ddd-template-postgres:5432/application-database
# DATA_MONGODB_HOST=ddd-template-mongo
# DATA_NEO4J_URI=neo4j://ddd-template-neo4j:7687

# ==================================================================
# Production Overrides (Prod Profile)
# ==================================================================
# These should be set via environment variables in production
# SPRING_DATASOURCE_URL=${DATABASE_URL}
# SPRING_DATASOURCE_USERNAME=${DATABASE_USERNAME}
# SPRING_DATASOURCE_PASSWORD=${DATABASE_PASSWORD}
# JWT_PUBLIC_KEY=${JWT_PUBLIC_KEY}
# JWT_PRIVATE_KEY=${JWT_PRIVATE_KEY}